---
import type { CollectionEntry } from "astro:content";
import { formatDate, readingTime } from "@lib/utils";
import { buildTagOptions } from "@lib/simpleIconTags";
import ArticleShareActions from "@components/ArticleShareActions";
import TagBadge from "@components/TagBadge";
import { Separator } from "@/components/ui/separator";

import { Calendar, BookOpen, Globe, LinkIcon, ChevronLeft } from "lucide-react";

type Props = {
  entry: CollectionEntry<"projects">;
  shareUrl: string;
};

const { entry } = Astro.props;
const { collection, data, body = "" } = entry;
const { title, summary, date, tags = [] } = data;
const { shareUrl } = Astro.props;
const tagOptions = collection === "projects" ? buildTagOptions(tags) : [];

const demoUrl = collection === "projects" ? data.demoUrl : null;
const repoUrl = collection === "projects" ? data.repoUrl : null;
---

<div>
  <a
    href={`/${collection}`}
    class="group flex w-fit items-center gap-2 rounded-lg border border-border px-3 py-1.5 text-sm hover:bg-muted blend"
  >
    <ChevronLeft
      size={16}
      strokeWidth={2}
      className="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
      aria-hidden="true"
    />
    <div class="text-current group-hover:text-foreground group-hover:dark:text-foreground blend">
      Back to {collection}
    </div>
  </a>

  <div class="flex flex-wrap text-sm uppercase mt-6 gap-3">
    <div class="flex items-center gap-2">
      <Calendar
        className="size-5 stroke-current"
        aria-hidden="true"
      />
      {formatDate(date)}
    </div>

    <div class="flex items-center gap-2">
      <BookOpen
        className="size-5 stroke-current"
        aria-hidden="true"
      />
      {readingTime(body)}
    </div>
  </div>

  <h1 class="text-3xl font-semibold text-foreground mt-2">
    {title}
  </h1>

  <div class="article-content mt-1">
    {summary}
  </div>

  {
    (demoUrl || repoUrl || shareUrl) && (
      <div class="mt-4 space-y-2">
        <div class="flex flex-wrap gap-2">
          {demoUrl && (
            <a
              href={demoUrl}
              target="_blank"
              class="group flex gap-2 items-center px-3 py-1.5 truncate rounded-lg text-sm md:text-sm lg:text-base border border-foreground/25 dark:border-foreground/25 hover:bg-foreground/5 hover:dark:bg-foreground/15 blend"
            >
              <Globe
                size={16}
                strokeWidth={2}
                className="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
                aria-hidden="true"
              />
              <span class="text-current group-hover:text-foreground group-hover:dark:text-foreground blend">
                See Demo
              </span>
            </a>
          )}

          {repoUrl && (
            <a
              href={repoUrl}
              target="_blank"
              class="group flex gap-2 items-center px-3 py-1.5 truncate rounded-lg text-sm md:text-sm lg:text-base border border-foreground/25 dark:border-foreground/25 hover:bg-foreground/5 hover:dark:bg-foreground/15 blend"
            >
              <LinkIcon
                size={16}
                strokeWidth={2}
                className="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
                aria-hidden="true"
              />
              <span class="text-current group-hover:text-foreground group-hover:dark:text-foreground blend">
                See Repository
              </span>
            </a>
          )}

          <ArticleShareActions
            client:idle
            title={title}
            summary={summary}
            url={shareUrl}
          />
        </div>

        {
          tagOptions.length > 0 && (
            <div class="space-y-3 py-3">
              <Separator className="h-px w-full bg-black/20 dark:bg-white/20" />
              <div class="text-xs font-medium uppercase tracking-[0.24em] text-black/55 dark:text-white/55">
                Tags
              </div>
              <div class="flex flex-wrap gap-2">
              {tagOptions.map((tag) => (
                <div class="group flex items-center px-3 py-1.5 rounded-lg text-sm md:text-sm lg:text-base border border-foreground/25 dark:border-foreground/25 hover:bg-foreground/5 hover:dark:bg-foreground/15 blend">
                  <TagBadge
                    tag={tag}
                    iconClassName="size-4"
                    labelClassName="text-current"
                    className="text-current group-hover:text-foreground group-hover:dark:text-foreground blend"
                  />
                </div>
              ))}
              </div>
            </div>
          )
        }
      </div>
    )
  }
</div>
