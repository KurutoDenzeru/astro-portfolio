---
// Assets
import "@/styles/global.css";
import { Image } from "astro:assets";
import hand from "@assets/hand.webp";
import creative from "@assets/creative.webp";
import freestyle from "@assets/freestyle.webp";


import { SITE, SOCIALS } from "@consts";
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import { withProjectPreviews, type ProjectEntryWithPreview } from "@lib/projectPreviews";
import { buildTagOptions } from "@lib/simpleIconTags";

// Components:
import ArrowCard from "@components/ArrowCard";
import StackCard from "@components/StackCard.astro";
import MeteorShower from "@components/MeteorShower.astro";
import TwinklingStars from "@components/TwinklingStars.astro";
import { FileText, ChevronRight } from "lucide-react";

const projects: ProjectEntryWithPreview[] = await withProjectPreviews((await getCollection("projects"))
	.filter((project) => !project.data.draft)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3));

const stack = [
	// { text: "HTML", icon: "html", href: "https://www.w3schools.com/html/" },
	// { text: "CSS", icon: "css", href: "https://www.w3schools.com/css/" },
	{
		text: "JavaScript",
		icon: "javascript",
		href: "https://www.javascript.com",
	},
	{
		text: "TypeScript",
		icon: "typescript",
		href: "https://www.typescriptlang.org",
	},
	{ text: "Node.js", icon: "node", href: "https://nodejs.org/en" },
	{ text: "Android", icon: "android", href: "https://developer.android.com/" },
	{ text: "Godot", icon: "godotengine", href: "https://godotengine.org/" },
	{ text: "React.js", icon: "react", href: "https://react.dev/" },
	{ text: "Next.js", icon: "next", href: "https://nextjs.org/" },
	{ text: "TanStack", icon: "tanstack", href: "https://tanstack.com/" },
	{ text: "Swift", icon: "swift", href: "https://www.swift.org/" },
	{ text: "Vue.js", icon: "vue", href: "https://vuejs.org/" },
	{ text: "Nuxt.js", icon: "nuxt", href: "https://nuxt.com/" },
	{ text: "Capacitor", icon: "capacitor", href: "https://capacitorjs.com/" },
	{ text: "Electron", icon: "electron", href: "https://www.electronjs.org/" },
	// { text: "Astro", icon: "astro", href: "https://astro.build"},
	{ text: "PHP", icon: "php", href: "https://www.php.net/" },
	{ text: "Python", icon: "python", href: "https://www.python.org/" },
	{ text: "Laravel", icon: "laravel", href: "https://laravel.com/" },
	{ text: "Tailwind", icon: "tailwind", href: "https://tailwindcss.com" },
	{ text: "shadcn/ui", icon: "shadcn/ui", href: "https://ui.shadcn.com/" },
	{ text: "Storybook", icon: "storybook", href: "https://storybook.js.org/" },
	{ text: "Vite", icon: "vite", href: "https://vite.dev/" },
	{ text: "MySQL", icon: "mysql", href: "https://www.mysql.com/" },
	{ text: "SQLite", icon: "sqlite", href: "https://www.sqlite.org/" },
	{
		text: "PostgreSQL",
		icon: "postgresql",
		href: "https://www.postgresql.org/",
	},
	{ text: "MongoDB", icon: "mongodb", href: "https://www.mongodb.com/" },
	{ text: "Redis", icon: "redis", href: "https://redis.io/" },
	{ text: "Firebase", icon: "firebase", href: "https://firebase.google.com/" },
	{ text: "Convex", icon: "convex", href: "https://www.convex.dev/" },
	{ text: "Supabase", icon: "supabase", href: "https://supabase.com/" },
	{ text: "AWS", icon: "aws", href: "https://aws.amazon.com/" },
	{ text: "NVM", icon: "nvm", href: "https://github.com/nvm-sh/nvm" },
	{ text: "GNU Bash", icon: "gnubash", href: "https://www.gnu.org/software/bash/" },
	{ text: "Docker", icon: "docker", href: "https://www.docker.com/" },
	{ text: "Git", icon: "git", href: "https://git-scm.com/" },
	{ text: "Postman", icon: "postman", href: "https://www.postman.com/" },
	{ text: "GNU / Linux", icon: "linux", href: "https://www.linux.org/" },
	{ text: "Figma", icon: "figma", href: "https://www.figma.com/" },
];

function chunkStack<T>(items: T[], parts: number) {
	const size = Math.ceil(items.length / parts);
	return Array.from({ length: parts }, (_, index) =>
		items.slice(index * size, (index + 1) * size),
	).filter((row) => row.length > 0);
}

const desktopStackRows = chunkStack(stack, 2);
const mobileStackRows = chunkStack(stack, 3);
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>
	<script is:inline src="/js/bg.js"></script>

	<!-- Hero Section -->
	<section class="relative h-screen w-full overflow-hidden">
		<!-- Light Mode: Particles -->
		<div class="absolute inset-0 block dark:hidden">
			<div id="particles1" class="absolute inset-0"></div>
			<div id="particles2" class="absolute inset-0"></div>
			<div id="particles3" class="absolute inset-0"></div>
		</div>

		<!-- Dark Theme: Stars -->
		<div class="absolute inset-0 bg-black hidden dark:block">
			<div id="stars1" class="absolute inset-0"></div>
			<div id="stars2" class="absolute inset-0"></div>
			<div id="stars3" class="absolute inset-0"></div>
		</div>

		<!-- Dark Theme: Twinkling Stars / Meteors -->
		<div id="galaxy" class="absolute inset-0 pointer-events-none">
			<div class="hidden dark:block">
				<TwinklingStars />
				<MeteorShower />
			</div>
		</div>

		<div
			id="planetcont"
			class="animate absolute inset-0 top-1/4 overflow-hidden"
		>
			<div
				id="crescent"
				class="absolute top-0 left-1/2 -translate-x-1/2 w-[250vw] min-h-screen aspect-square rounded-full p-px bg-linear-to-b from-black/25 dark:from-white/75 from-0% to-transparent to-5%"
			>
				<div
					id="planet"
					class="w-full h-full bg-white dark:bg-black rounded-full p-px overflow-hidden flex justify-center"
				>
					<div
						id="blur"
						class="w-full h-20 rounded-full bg-neutral-900/25 dark:bg-white/25 blur-3xl"
					>
					</div>
				</div>
			</div>
		</div>
		<div
			class="animate absolute h-full w-full flex items-center justify-center"
		>
			<div class="relative w-full h-full flex items-center justify-center">
				<div class="p-5 text-center">
					<p
						class="animated text-lg md:text-xl lg:text-2xl font-semibold opacity-75"
					>
						Hey there
						<span>
							<Image
								src={hand}
								alt="Wave"
								loading="eager"
								class="w-7 h-7 inline animate-wave"
							/>
						</span>
						I am
					</p>
					<p
						class="animated text-5xl md:text-6xl lg:text-7xl font-bold uppercase text-black dark:text-white animate-pulse"
					>
						Kurt Calacday
					</p>
					<p class="animated text-sm md:text-base lg:text-lg opacity-75">
						Senior Software Engineer / Full Stack Developer
					</p>
					<div
						id="ctaButtons"
						class="animated flex flex-wrap gap-4 justify-center mt-5"
					>
						<a
							href="/Resume.pdf"
							download="Resume.pdf"
							class="group flex items-center gap-2 py-2 px-4 rounded-lg truncate text-sm md:text-sm lg:text-base bg-black dark:bg-white text-white dark:text-black hover:opacity-75 blend"
						>
							<FileText size={16} strokeWidth={2} className="size-4 stroke-current" aria-hidden="true" />
							<span>Check my resume</span>
						</a>
						<a
							href="/work"
							class="group flex items-center gap-2 py-2 px-4 truncate-lg rounded-lg text-sm md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend"
						>
							<span>View my projects</span>
							<ChevronRight size={16} strokeWidth={2} className="size-4 stroke-current" aria-hidden="true" />
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div class="relative bg-white dark:bg-black">
    <div class="mx-auto max-w-5xl p-5 space-y-24">

      <!-- About Section -->
      <section class="animate">

          <div class="gap-6 items-center mx-auto lg:grid lg:grid-cols-2">
              <div class="text-black sm:text-lg dark:text-white">
                  <!-- <p class="text-xl font-semibold text-black dark:text-white">About me</p> -->

                <p class="mb-4">Senior Full Stack Engineer, passionate about building efficient,
									scalable, and user-centric web applications.</p>

                <p class="mb-4">
                  With a proven track record in full-stack development—specializing in <b>JavaScript</b> and
                  <b>TypeScript</b> ecosystems including <b>React.js, Next.js, Vue.js / Nuxt.js, TanStack,</b> and
                  <b>Node.js</b>—I build seamless, scalable, and user-focused applications.
                </p>

                <p>My experience also covers modern web development with tools like <b>Bootstrap, Tailwind</b> and
                  <b>shadcn/ui</b>, alongside robust back-end solutions utilizing databases such as
                  <b>PostgreSQL, MySQL</b> and <b>MongoDB.</b>
                </p>

              </div>
              <div class="grid grid-cols-2 gap-4 items-center mx-auto">
                  <Image src={creative} loading="lazy" alt="Speaking" class=" w-auto h-auto rounded-lg shadow-lg" />
                  <Image src={freestyle} loading="lazy" alt="Speaking" class="mt-6 w-auto h-auto lg:mt-14 rounded-lg  shadow-lg" />
              </div>
          </div>

      </section>

      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white text-xl">
            Tech Stack
          </p>
          <div class="relative mt-5 space-y-3 overflow-hidden">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-12 bg-linear-to-r from-white via-white/90 to-transparent dark:from-black dark:via-black/90 md:w-16"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-12 bg-linear-to-l from-white via-white/90 to-transparent dark:from-black dark:via-black/90 md:w-16"></div>
            <div class="space-y-3 md:block hidden">
              {desktopStackRows.map((row, rowIndex) => (
                <div class="tech-marquee">
                  <div
                    class:list={["tech-marquee-track", rowIndex % 2 === 1 && "tech-marquee-track-reverse"]}
                    style={`--marquee-duration:${Math.max(row.length * 4, 22)}s;`}
                  >
                    <div class="tech-marquee-group">
                      {row.map((item) => (
                        <StackCard
                          text={item.text}
                          icon={item.icon}
                          href={item.href}
                        />
                      ))}
                    </div>
                    <div class="tech-marquee-group" aria-hidden="true">
                      {row.map((item) => (
                        <StackCard
                          text={item.text}
                          icon={item.icon}
                          href={item.href}
                        />
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="space-y-3 md:hidden">
              {mobileStackRows.map((row, rowIndex) => (
                <div class="tech-marquee">
                  <div
                    class:list={["tech-marquee-track", rowIndex % 2 === 1 && "tech-marquee-track-reverse"]}
                    style={`--marquee-duration:${Math.max(row.length * 4.5, 20)}s;`}
                  >
                    <div class="tech-marquee-group">
                      {row.map((item) => (
                        <StackCard
                          text={item.text}
                          icon={item.icon}
                          href={item.href}
                        />
                      ))}
                    </div>
                    <div class="tech-marquee-group" aria-hidden="true">
                      {row.map((item) => (
                        <StackCard
                          text={item.text}
                          icon={item.icon}
                          href={item.href}
                        />
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white text-xl">
              Recent projects
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All projects
              </span>

            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
							<li>
                <ArrowCard client:idle entry={project} tagOptions={buildTagOptions(project.data.tags)} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <h2 class="font-semibold text-black dark:text-white text-lg">
            Let's Connect
          </h2>
          <p>
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>
</PageLayout>

<style>
  .tech-marquee {
    --tech-marquee-gap: 0.75rem;
    overflow: hidden;
  }

  .tech-marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    gap: var(--tech-marquee-gap);
    will-change: transform;
    animation: tech-marquee-left var(--marquee-duration, 28s) linear infinite;
    transform: translate3d(0, 0, 0);
  }

  .tech-marquee-group {
    display: flex;
    width: max-content;
    flex: none;
    align-items: center;
    gap: var(--tech-marquee-gap);
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .tech-marquee-group > * {
    flex: none;
  }

  .tech-marquee-track-reverse {
    animation-name: tech-marquee-right;
  }

  .tech-marquee:hover .tech-marquee-track {
    animation-play-state: paused;
  }

  @keyframes tech-marquee-left {
    from {
      transform: translate3d(0, 0, 0);
    }

    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes tech-marquee-right {
    from {
      transform: translate3d(-50%, 0, 0);
    }

    to {
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-marquee-track,
    .tech-marquee-track-reverse {
      animation: none;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .tech-marquee-group {
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
    }

    .tech-marquee-group[aria-hidden="true"] {
      display: none;
    }
  }
</style>
