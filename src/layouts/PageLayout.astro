---
import "@styles/global.css";
import { type CollectionEntry, getCollection } from "astro:content";
import BaseHead from "@components/BaseHead.astro";
import ClientToaster from "@components/ClientToaster";
import CookieConsent from "@components/CookieConsent";
import Footer from "@components/Footer.astro";
import GlobalSearchDialog from "@components/GlobalSearchDialog";
import Header from "@components/Header.astro";
import MarkdownEnhancer from "@components/MarkdownEnhancer";
import { withProjectPreviews } from "@lib/projectPreviews";
import { buildTagOptions } from "@lib/simpleIconTags";

const { title, description, image } = Astro.props;

import { SITE } from "@consts";

const projectSearchEntries = await withProjectPreviews(
  (await getCollection("projects"))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
).then((projects) =>
  projects.map((project) => ({
    href: `/${project.collection}/${project.id}`,
    id: project.id,
    summary: project.data.summary,
    tags: project.data.tags,
    tagOptions: buildTagOptions(project.data.tags),
    title: project.data.title,
    draft: project.data.draft ?? false,
  })),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${title} | ${SITE.TITLE}`}
      description={description}
      image={image}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent client:idle />
    <ClientToaster client:idle />
    <GlobalSearchDialog client:idle projects={projectSearchEntries} />
    <MarkdownEnhancer client:idle />
  </body>
</html>
