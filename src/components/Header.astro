---
// filepath: /Users/kurtcalacday/Documents/Projects/astro-app/src/components/Header.astro
import Container from "@components/Container.astro";
import CustomTooltip from "@components/CustomTooltip.astro";
import { SITE } from "@consts";
import { cn } from "@lib/utils";

const { pathname } = Astro.url;
const subpath = pathname.match(/[^/]+/g);
const isProjectsActive = pathname === "/projects" || "/" + subpath?.[0] === "/projects";
const isWorkActive = pathname === "/work" || "/" + subpath?.[0] === "/work";

// lucide astro icons (server-rendered components, not raw <svg> tags)
import {
  Rss,
  Moon,
  Sun,
  Search,
  Home,
  Briefcase,
  FolderOpen,
} from "lucide-react";

const tooltipShortcutClass = "inline-flex h-5 min-w-5 items-center justify-center rounded-sm bg-background/20 px-1 text-[11px] font-medium text-background dark:bg-background/10";
---

<header
  id="header"
  class="fixed bottom-4 md:bottom-auto md:top-4 left-0 md:left-1/2 md:-translate-x-1/2 right-0 md:right-auto md:w-auto h-20 md:h-auto z-50"
>
  <Container size="lg">
    <div
      class="relative h-full w-full flex items-center justify-center px-4 md:px-0"
    >
      <!-- Center Dock Navigation (Desktop & Mobile) -->
      <nav id="dock-nav" class="flex items-center justify-center gap-2">
        <div class="glass-dock flex items-center gap-2 px-3 py-2 rounded-2xl">
          <!-- Mobile: Logo, Navigation, and Hamburger Menu -->
          <div class="md:hidden flex items-center gap-2">
            <!-- Mobile: Logo -->
            <a
              href="/"
              aria-label="Home"
              class={cn(
                "size-10 rounded-xl p-1.5 flex items-center justify-center",
                "transition-all duration-300 ease-in-out",
                "hover:bg-black/5 dark:hover:bg-white/10",
              )}
            >
              <picture class="size-full">
                <img
                  src="/icons/brand_black.svg"
                  alt={`${SITE.TITLE} logo`}
                  width="40"
                  height="40"
                  class="w-full h-full block dark:hidden"
                  loading="lazy"
                />
                <img
                  src="/icons/brand_white.svg"
                  alt={`${SITE.TITLE} logo`}
                  width="40"
                  height="40"
                  class="w-full h-full hidden dark:block"
                  loading="lazy"
                />
              </picture>
            </a>
            <div class="w-px h-6 bg-black/10 dark:bg-white/20 mx-1"></div>

            <!-- Mobile: Navigation icons only -->
            <CustomTooltip text="Home" side="bottom">
              <a
                href="/"
                aria-label="Home"
                data-shortcut-href="/"
                class={cn(
                  "size-10 rounded-xl p-2 flex items-center justify-center",
                  "transition-all duration-300 ease-in-out",
                  pathname === "/"
                    ? "bg-black/10 dark:bg-white/20 scale-110"
                    : "hover:bg-black/5 dark:hover:bg-white/10 hover:scale-105",
                )}
              >
                <Home className="w-5 h-5 text-gray-900 dark:text-white" />
              </a>
            </CustomTooltip>
            <CustomTooltip text="Work" side="bottom">
              <a
                href="/work"
                aria-label="Work"
                data-shortcut-href="/work"
                class={cn(
                  "size-10 rounded-xl p-2 flex items-center justify-center",
                  "transition-all duration-300 ease-in-out",
                  isWorkActive
                    ? "bg-black/10 dark:bg-white/20 scale-110"
                    : "hover:bg-black/5 dark:hover:bg-white/10 hover:scale-105",
                )}
              >
                <Briefcase className="w-5 h-5 text-gray-900 dark:text-white" />
              </a>
            </CustomTooltip>
            <CustomTooltip text="Projects" side="bottom">
              <a
                href="/projects"
                aria-label="Projects"
                data-shortcut-href="/projects"
                class={cn(
                  "size-10 rounded-xl p-2 flex items-center justify-center",
                  "transition-all duration-300 ease-in-out",
                  isProjectsActive
                    ? "bg-black/10 dark:bg-white/20 scale-110"
                    : "hover:bg-black/5 dark:hover:bg-white/10 hover:scale-105",
                )}
              >
                <FolderOpen className="w-5 h-5 text-gray-900 dark:text-white" />
              </a>
            </CustomTooltip>
            <!-- Mobile: Divider before hamburger -->
            <div class="w-px h-6 bg-black/10 dark:bg-white/20 mx-1"></div>

            <!-- Mobile: Search -->
            <button
              type="button"
              data-open-global-search
              aria-label="Search projects"
              class={cn(
                "size-10 rounded-xl p-2 flex items-center justify-center cursor-pointer",
                "transition-all duration-300 ease-in-out",
                "hover:bg-black/5 dark:hover:bg-white/10 hover:scale-105",
              )}
            >
              <Search className="text-gray-900 dark:text-white w-5 h-5 cursor-pointer" />
            </button>
          </div>

          <!-- Desktop Navigation (hidden on mobile) -->
          <div class="hidden md:flex items-center gap-2">
            <!-- Desktop: Logo with label -->
            <a
              href="/"
              class={cn(
                "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5 cursor-pointer",
                "transition-all duration-300 ease-in-out",
                "hover:bg-black/5 dark:hover:bg-white/10",
                "group overflow-hidden dock-brand",
              )}
            >
              <picture class="size-7 shrink-0">
                <img
                  src="/icons/brand_black.svg"
                  alt={`${SITE.TITLE} logo`}
                  width="28"
                  height="28"
                  class="w-full h-full block dark:hidden"
                  loading="eager"
                />
                <img
                  src="/icons/brand_white.svg"
                  alt={`${SITE.TITLE} logo`}
                  width="28"
                  height="28"
                  class="w-full h-full hidden dark:block"
                  loading="eager"
                />
              </picture>
              <span
                class="dock-label text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap"
              >
                {SITE.TITLE}
              </span>
            </a>
            <div
              class="hidden md:block w-px h-6 bg-black/10 dark:bg-white/20 mx-1"
            >
            </div>

            <!-- Desktop: All icons with expandable labels -->
            <div class="custom-tooltip-wrapper group relative hidden md:inline-flex">
              <a
                href="/"
                aria-label="Home"
                data-shortcut-href="/"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden",
                  pathname === "/"
                    ? "bg-black/10 dark:bg-white/20 dock-active"
                    : "hover:bg-black/5 dark:hover:bg-white/10",
                )}
              >
                <Home
                  className="w-5 h-5 text-gray-900 dark:text-white shrink-0"
                />
              </a>
              <div
                class="custom-tooltip absolute hidden group-hover:block top-full mt-2 left-1/2 -translate-x-1/2 bg-foreground text-background px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap z-50 pointer-events-none animate-in fade-in-0 zoom-in-95 duration-200 dark:bg-foreground dark:text-background"
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span>Home</span>
                  <span id="home-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Alt</span>
                    <span class={tooltipShortcutClass}>1</span>
                  </span>
                </span>
                <div class="custom-tooltip-arrow absolute w-0 h-0 border-4 bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent left-1/2 -translate-x-1/2"></div>
              </div>
            </div>
            <div class="custom-tooltip-wrapper group relative hidden md:inline-flex">
              <a
                href="/work"
                aria-label="Work"
                data-shortcut-href="/work"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden",
                  isWorkActive
                    ? "bg-black/10 dark:bg-white/20 dock-active"
                    : "hover:bg-black/5 dark:hover:bg-white/10",
                )}
              >
                <Briefcase
                  className="w-5 h-5 text-gray-900 dark:text-white shrink-0"
                />
              </a>
              <div
                class="custom-tooltip absolute hidden group-hover:block top-full mt-2 left-1/2 -translate-x-1/2 bg-foreground text-background px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap z-50 pointer-events-none animate-in fade-in-0 zoom-in-95 duration-200 dark:bg-foreground dark:text-background"
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span>Work</span>
                  <span id="work-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Alt</span>
                    <span class={tooltipShortcutClass}>2</span>
                  </span>
                </span>
                <div class="custom-tooltip-arrow absolute w-0 h-0 border-4 bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent left-1/2 -translate-x-1/2"></div>
              </div>
            </div>
            <div class="custom-tooltip-wrapper group relative hidden md:inline-flex">
              <a
                href="/projects"
                aria-label="Projects"
                data-shortcut-href="/projects"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden",
                  isProjectsActive
                    ? "bg-black/10 dark:bg-white/20 dock-active"
                    : "hover:bg-black/5 dark:hover:bg-white/10",
                )}
              >
                <FolderOpen
                  className="w-5 h-5 text-gray-900 dark:text-white shrink-0"
                />
              </a>
              <div
                class="custom-tooltip absolute hidden group-hover:block top-full mt-2 left-1/2 -translate-x-1/2 bg-foreground text-background px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap z-50 pointer-events-none animate-in fade-in-0 zoom-in-95 duration-200 dark:bg-foreground dark:text-background"
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span>Projects</span>
                  <span id="projects-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Alt</span>
                    <span class={tooltipShortcutClass}>3</span>
                  </span>
                </span>
                <div class="custom-tooltip-arrow absolute w-0 h-0 border-4 bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent left-1/2 -translate-x-1/2"></div>
              </div>
            </div>
            <div
              class="hidden md:block w-px h-6 bg-black/10 dark:bg-white/20 mx-1"
            >
            </div>
            <div class="custom-tooltip-wrapper group relative hidden md:inline-flex">
              <button
                type="button"
                data-open-global-search
                aria-label="Search projects"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden cursor-pointer",
                  "hover:bg-black/5 dark:hover:bg-white/10",
                )}
              >
                <Search
                  className="w-5 h-5 text-gray-900 dark:text-white shrink-0"
                />
              </button>

              <div
                class={`
                custom-tooltip
                absolute hidden group-hover:block
                top-full mt-2 left-1/2 -translate-x-1/2
                bg-foreground text-background
                px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap
                z-50 pointer-events-none
                animate-in fade-in-0 zoom-in-95 duration-200
                dark:bg-foreground dark:text-background
              `}
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span>Search</span>
                  <span id="search-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Ctrl</span>
                    <span class={tooltipShortcutClass}>K</span>
                  </span>
                </span>
                <div
                  class={`
                  custom-tooltip-arrow
                  absolute w-0 h-0
                  border-4
                  bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent
                  left-1/2 -translate-x-1/2
                `}
                >
                </div>
              </div>
            </div>
            <div class="custom-tooltip-wrapper group relative hidden md:inline-flex">
              <a
                href="/rss.xml"
                target="_blank"
                rel="noopener"
                aria-label="Subscribe"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden",
                  "hover:bg-black/5 dark:hover:bg-white/10",
                )}
              >
                <Rss
                  className="w-5 h-5 text-gray-900 dark:text-white shrink-0"
                />
              </a>
              <div
                class="custom-tooltip absolute hidden group-hover:block top-full mt-2 left-1/2 -translate-x-1/2 bg-foreground text-background px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap z-50 pointer-events-none animate-in fade-in-0 zoom-in-95 duration-200 dark:bg-foreground dark:text-background"
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span>Subscribe</span>
                  <span id="subscribe-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Alt</span>
                    <span class={tooltipShortcutClass}>4</span>
                  </span>
                </span>
                <div class="custom-tooltip-arrow absolute w-0 h-0 border-4 bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent left-1/2 -translate-x-1/2"></div>
              </div>
            </div>
            <div
              id="theme-tooltip-wrapper"
              class="custom-tooltip-wrapper group relative inline-flex"
            >
              <button
                id="header-theme-button"
                aria-label="Toggle theme"
                class={cn(
                  "hidden md:flex items-center gap-2 rounded-xl px-2 py-1.5",
                  "transition-all duration-300 ease-in-out",
                  "group overflow-hidden",
                  "hover:bg-black/5 dark:hover:bg-white/10",
                  "cursor-pointer",
                )}
              >
                <Sun
                  className="block dark:hidden text-gray-900 w-5 h-5 shrink-0"
                />
                <Moon
                  className="hidden dark:block text-white w-5 h-5 shrink-0"
                />
              </button>

              <!-- Dynamic tooltip for theme button -->
              <div
                id="theme-tooltip"
                class={`
                custom-tooltip
                absolute hidden group-hover:block
                top-full mt-2 left-1/2 -translate-x-1/2
                bg-foreground text-background
                px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap
                z-50 pointer-events-none
                animate-in fade-in-0 zoom-in-95 duration-200
                dark:bg-foreground dark:text-background
              `}
                role="tooltip"
              >
                <span class="inline-flex items-center gap-2">
                  <span id="theme-tooltip-text">Light mode</span>
                  <span id="theme-tooltip-shortcut" class="inline-flex items-center gap-1">
                    <span class={tooltipShortcutClass}>Alt</span>
                    <span class={tooltipShortcutClass}>D</span>
                  </span>
                </span>

                <!-- Arrow -->
                <div
                  class={`
                  custom-tooltip-arrow
                  absolute w-0 h-0
                  border-4
                  bottom-full border-b-foreground border-l-transparent border-r-transparent border-t-transparent
                  left-1/2 -translate-x-1/2
                `}
                >
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
    </div>
  </Container>
</header>

<style>
  /* Brand label: always visible; other labels are removed and replaced with native tooltips */
  .dock-brand .dock-label {
    display: inline-block;
    opacity: 1;
    margin-left: 0.5rem;
    color: inherit;
    font-weight: 600;
  }
</style>

<script type="module">
  import "/js/theme.js";

  // Update theme tooltip based on current theme
  function updateThemeTooltip() {
    const btn = document.getElementById("header-theme-button");
    const tooltip = document.getElementById("theme-tooltip");
    const tooltipText = document.getElementById("theme-tooltip-text");
    if (!btn || !tooltip || !tooltipText) return;
    const isDark = document.documentElement.classList.contains("dark");
    const label = isDark ? "Dark mode" : "Light mode";
    tooltipText.textContent = label;
    // Helpful for screen readers: include current state
    btn.setAttribute("aria-label", `Toggle theme — ${label}`);
  }

  // Initialize theme tooltip on load
  updateThemeTooltip();

  // Update theme tooltip when theme changes
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === "class") {
        updateThemeTooltip();
      }
    });
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["class"],
  });

  function initializeGlobalSearchButtons() {
    document.querySelectorAll("[data-open-global-search]").forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      if (button.dataset.globalSearchBound === "true") return;
      button.dataset.globalSearchBound = "true";
      button.addEventListener("click", () => {
        window.dispatchEvent(new Event("open-global-search"));
      });
    });
  }

  function updateSearchTooltipShortcut() {
    const shortcut = document.getElementById("search-tooltip-shortcut");
    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    const html = (primary, secondary) =>
      `<span class="${primary}">${secondary[0]}</span><span class="${primary}">${secondary[1]}</span>`;
    const badgeClass = "inline-flex h-5 min-w-5 items-center justify-center rounded-sm bg-background/20 px-1 text-[11px] font-medium text-background dark:bg-background/10";
    const shortcutMap = {
      "search-tooltip-shortcut": isMac ? ["⌘", "K"] : ["Ctrl", "K"],
      "home-tooltip-shortcut": isMac ? ["⌘", "1"] : ["Alt", "1"],
      "work-tooltip-shortcut": isMac ? ["⌘", "2"] : ["Alt", "2"],
      "projects-tooltip-shortcut": isMac ? ["⌘", "3"] : ["Alt", "3"],
      "subscribe-tooltip-shortcut": isMac ? ["⌘", "4"] : ["Alt", "4"],
      "theme-tooltip-shortcut": isMac ? ["⌘", "D"] : ["Alt", "D"],
    };

    Object.entries(shortcutMap).forEach(([id, keys]) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.innerHTML = html(badgeClass, keys);
    });
  }

  function initializeGlobalShortcuts() {
    if (window.__global_shortcuts_initialized__) return;
    window.__global_shortcuts_initialized__ = true;

    window.addEventListener("keydown", (event) => {
      const target = event.target;
      if (
        target instanceof HTMLElement &&
        (target.isContentEditable ||
          target.tagName === "INPUT" ||
          target.tagName === "TEXTAREA" ||
          target.tagName === "SELECT")
      ) {
        return;
      }

      const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
      const usesMeta = isMac ? event.metaKey : event.altKey;
      if (!usesMeta) return;

      const key = event.key.toLowerCase();
      if (key === "1") {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent("global-shortcut:navigate", { detail: { href: "/" } }));
      } else if (key === "2") {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent("global-shortcut:navigate", { detail: { href: "/work" } }));
      } else if (key === "3") {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent("global-shortcut:navigate", { detail: { href: "/projects" } }));
      } else if (key === "4") {
        event.preventDefault();
        window.open("/rss.xml", "_blank", "noopener,noreferrer");
      } else if (key === "d") {
        event.preventDefault();
        window.dispatchEvent(new Event("global-shortcut:toggle-theme"));
      }
    });
  }

  // Initialize on load and after Astro swaps
  document.addEventListener("astro:after-swap", () => {
    initializeGlobalSearchButtons();
    initializeGlobalShortcuts();
    updateSearchTooltipShortcut();
    updateThemeTooltip();
  });
  initializeGlobalSearchButtons();
  initializeGlobalShortcuts();
  updateSearchTooltipShortcut();
</script>
