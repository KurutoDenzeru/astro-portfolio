---
import "@styles/global.css";
import { Button } from "@/components/ui/button";
import { Cookie, Info, X } from "lucide-react";
---

<div
  class="hidden md:block fixed right-4 left-4 md:right-4 md:left-auto z-10 max-w-sm p-4 rounded-lg border
    bg-white/70 dark:bg-black/50
    border-black/10 dark:border-white/20
    backdrop-blur-2xl saturate-150
    shadow-lg shadow-black/5 dark:shadow-black/20
    bottom-28 md:bottom-4"
  id="cookie-consent-desktop"
  aria-live="polite"
  hidden
  style="will-change: transform, opacity; transform: translateZ(0);"
>
  <div class="flex items-start gap-3">
    <div class="flex-1">
      <div class="flex items-center justify-between gap-2">
        <a
          href="/legal/privacy"
          aria-label="Read our Privacy Policy"
          class="text-sm font-semibold inline-flex items-center gap-2 hover:underline focus-visible:underline underline-offset-2"
        >
          <Info
            size={16}
            strokeWidth={2}
            className="size-4 stroke-current"
            aria-hidden="true"
          />
          <span>We use cookies</span>
        </a>
        <Button
          data-consent-close="panel"
          type="button"
          variant="ghost"
          className="h-7 w-7 p-0 rounded-md border border-black/10 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/10"
          aria-label="Close cookie consent panel"
        >
          <X size={14} strokeWidth={2} className="size-3.5 stroke-current" aria-hidden="true" />
        </Button>
      </div>
      <p class="mt-1 text-sm text-muted-foreground">
        Anonymous analytics help improve the site. You can accept or reject
        below.
      </p>
      <div class="mt-3 flex items-center gap-2">
        <Button
          data-consent-action="accept"
          type="button"
          className="inline-flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 min-w-22 box-border"
          >Accept</Button
        >
        <Button
          variant="outline"
          data-consent-action="reject"
          type="button"
          className="inline-flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium border bg-background hover:bg-accent min-w-22 box-border"
          >Reject</Button
        >
      </div>
    </div>
  </div>
</div>

<div
  class="fixed right-0 bottom-26 md:bottom-8 z-30 transition-all duration-200 ease-out opacity-0 translate-x-3"
  id="cookie-consent-trigger"
  hidden
>
  <button
    data-consent-toggle="panel"
    type="button"
    class="inline-flex items-center gap-2 rounded-l-xl rounded-r-none border border-r-0 px-2.5 py-3 text-xs font-medium
      bg-white/70 dark:bg-black/50
      border-black/10 dark:border-white/20
      backdrop-blur-2xl saturate-150
      text-black/90 dark:text-white/90
      shadow-md shadow-black/5 dark:shadow-black/20
      hover:bg-white/80 hover:dark:bg-black/60
      transition-colors duration-200 cursor-pointer"
    style="writing-mode: vertical-rl; text-orientation: sideways;"
    aria-controls="cookie-consent-desktop cookie-consent-mobile-panel"
    aria-expanded="false"
    aria-label="Open cookie settings"
  >
    <Cookie
      size={14}
      strokeWidth={2}
      className="size-3.5 stroke-current"
      aria-hidden="true"
    />
    <span>Cookie Settings</span>
  </button>
</div>

<div
  class="fixed right-4 left-4 md:right-4 md:left-auto max-w-sm p-4 rounded-lg border
    bg-white/70 dark:bg-black/50
    border-black/10 dark:border-white/20
    backdrop-blur-2xl saturate-150
    shadow-lg shadow-black/5 dark:shadow-black/20
    bottom-26 md:hidden z-30 transition-all duration-250 ease-out opacity-0 translate-y-4 scale-95 pointer-events-none"
  id="cookie-consent-mobile-panel"
  aria-live="polite"
  aria-modal="false"
  role="dialog"
  hidden
  style="will-change: transform, opacity; transform: translateZ(0);"
>
  <div class="flex items-start gap-3">
    <div class="flex-1">
      <div class="flex items-center justify-between gap-2">
        <a
          href="/legal/privacy"
          aria-label="Read our Privacy Policy"
          class="text-sm font-semibold inline-flex items-center gap-2 hover:underline focus-visible:underline underline-offset-2"
        >
          <Info
            size={16}
            strokeWidth={2}
            className="size-4 stroke-current"
            aria-hidden="true"
          />
          <span>We use cookies</span>
        </a>
        <Button
          data-consent-close="panel"
          type="button"
          variant="ghost"
          className="h-7 w-7 p-0 rounded-md border border-black/10 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/10"
          aria-label="Close cookie consent panel"
        >
          <X size={14} strokeWidth={2} className="size-3.5 stroke-current" aria-hidden="true" />
        </Button>
      </div>
      <p class="mt-1 text-sm text-muted-foreground">
        Anonymous analytics help improve the site. You can accept or reject
        below.
      </p>
      <div class="mt-3 flex items-center gap-2 flex-wrap">
        <Button
          data-consent-action="accept"
          type="button"
          className="inline-flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 min-w-22 box-border"
          >Accept</Button
        >
        <Button
          variant="outline"
          data-consent-action="reject"
          type="button"
          className="inline-flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium border bg-background hover:bg-accent min-w-22 box-border"
          >Reject</Button
        >
      </div>
    </div>
  </div>
</div>

<script>
  declare global {
    interface Window {
      __rybbit_loaded__?: boolean;
    }
  }

  (function () {
    try {
      const storageKey = "site:analytics:consent";
      const dismissedKey = "site:analytics:dismissed";
      const desktopEl = document.getElementById("cookie-consent-desktop");
      const mobilePanel = document.getElementById("cookie-consent-mobile-panel");
      const triggerEl = document.getElementById("cookie-consent-trigger");
      const toggleBtn = triggerEl
        ? triggerEl.querySelector("[data-consent-toggle='panel']")
        : null;
      let triggerCloseTimer: number | null = null;
      let mobilePanelCloseTimer: number | null = null;
      const accepted = localStorage.getItem(storageKey);
      const dismissed = localStorage.getItem(dismissedKey);
      function isMobile() {
        return (
          typeof window !== "undefined" &&
          window.matchMedia &&
          window.matchMedia("(max-width: 767px)").matches
        );
      }
      function setTriggerExpanded(expanded: boolean) {
        if (toggleBtn) {
          toggleBtn.setAttribute("aria-expanded", expanded ? "true" : "false");
        }
      }
      function clearTriggerCloseTimer() {
        if (triggerCloseTimer) {
          clearTimeout(triggerCloseTimer);
          triggerCloseTimer = null;
        }
      }
      function clearPanelCloseTimer() {
        if (mobilePanelCloseTimer) {
          clearTimeout(mobilePanelCloseTimer);
          mobilePanelCloseTimer = null;
        }
      }
      function showTrigger() {
        if (!triggerEl) return;
        clearTriggerCloseTimer();
        triggerEl.hidden = false;
        requestAnimationFrame(function () {
          triggerEl.classList.remove("opacity-0", "translate-x-3");
          triggerEl.classList.add("opacity-100", "translate-x-0");
        });
      }
      function hideTrigger(animated: boolean) {
        if (!triggerEl) return;
        clearTriggerCloseTimer();
        if (!animated) {
          triggerEl.hidden = true;
          triggerEl.classList.remove("opacity-100", "translate-x-0");
          triggerEl.classList.add("opacity-0", "translate-x-3");
          return;
        }
        triggerEl.classList.remove("opacity-100", "translate-x-0");
        triggerEl.classList.add("opacity-0", "translate-x-3");
        triggerCloseTimer = window.setTimeout(function () {
          if (triggerEl) triggerEl.hidden = true;
        }, 220);
      }
      function openMobilePanel() {
        if (!mobilePanel) return;
        clearPanelCloseTimer();
        mobilePanel.hidden = false;
        requestAnimationFrame(function () {
          mobilePanel.classList.remove(
            "opacity-0",
            "translate-y-4",
            "scale-95",
            "pointer-events-none",
          );
          mobilePanel.classList.add(
            "opacity-100",
            "translate-y-0",
            "scale-100",
            "pointer-events-auto",
          );
        });
      }
      function closeMobilePanel(animated: boolean) {
        if (!mobilePanel) return;
        clearPanelCloseTimer();
        if (!animated) {
          mobilePanel.hidden = true;
          mobilePanel.classList.remove(
            "opacity-100",
            "translate-y-0",
            "scale-100",
            "pointer-events-auto",
          );
          mobilePanel.classList.add(
            "opacity-0",
            "translate-y-4",
            "scale-95",
            "pointer-events-none",
          );
          return;
        }
        mobilePanel.classList.remove(
          "opacity-100",
          "translate-y-0",
          "scale-100",
          "pointer-events-auto",
        );
        mobilePanel.classList.add(
          "opacity-0",
          "translate-y-4",
          "scale-95",
          "pointer-events-none",
        );
        mobilePanelCloseTimer = window.setTimeout(function () {
          if (mobilePanel) mobilePanel.hidden = true;
        }, 240);
      }
      function show() {
        if (isMobile()) {
          hideTrigger(false);
          closeMobilePanel(false);
          openMobilePanel();
          setTriggerExpanded(true);
          if (desktopEl) desktopEl.hidden = true;
          return;
        }
        if (desktopEl) desktopEl.hidden = false;
        hideTrigger(false);
        closeMobilePanel(false);
        setTriggerExpanded(true);
      }
      function hide() {
        if (desktopEl) desktopEl.hidden = true;
        hideTrigger(true);
        closeMobilePanel(true);
        setTriggerExpanded(false);
      }
      function hidePanels() {
        if (desktopEl) desktopEl.hidden = true;
        closeMobilePanel(false);
        setTriggerExpanded(false);
      }
      function togglePanel() {
        if (isMobile()) {
          const willOpen = mobilePanel ? mobilePanel.hidden : false;
          if (willOpen) {
            hideTrigger(false);
            openMobilePanel();
          } else {
            closeMobilePanel(true);
            showTrigger();
          }
          setTriggerExpanded(willOpen);
          return;
        }

        if (!desktopEl) return;
        const willOpen = desktopEl.hidden;
        desktopEl.hidden = !willOpen ? true : false;
        if (willOpen) hideTrigger(false);
        else showTrigger();
        setTriggerExpanded(willOpen);
      }

      function loadAnalytics() {
        // Only load analytics on allowed production origins to avoid CORS issues during local dev
        try {
          const allowed = ["https://kurtcalacday.vercel.app"];
          // allow a dev override via query param or localStorage flag so you can test locally
          const forceFlag = (function () {
            try {
              if (
                location.search &&
                location.search.indexOf("forceAnalytics=1") !== -1
              )
                return true;
              return localStorage.getItem("site:analytics:force") === "true";
            } catch (e) {
              return false;
            }
          })();

          if (!allowed.includes(location.origin) && !forceFlag) {
            // skip loading analytics in non-prod (e.g. http://localhost:4321)
            console.info(
              "Analytics not loaded: origin not allowed",
              location.origin,
            );
            return;
          }
          if (forceFlag && !allowed.includes(location.origin)) {
            console.warn(
              "Analytics load forced in non-prod environment; CORS may still prevent network calls",
            );
          }
        } catch (e) {
          // if location isn't available for some reason, skip
          return;
        }

        // Rybbit Analytics (loads only on consent + allowed origin)
        // NOTE: Cloudflare Insights is disabled due to persistent 504 errors from their CDN
        try {
          if (!window.__rybbit_loaded__) {
            const r = document.createElement("script");
            r.defer = true;
            r.src = "https://app.rybbit.io/api/script.js";
            r.setAttribute("data-site-id", "a24aab4e28b1");
            r.crossOrigin = "anonymous";
            r.onload = function () {
              console.log("Rybbit Analytics: script loaded");
              try {
                window.__rybbit_loaded__ = true;
              } catch (e) {}
            };
            r.onerror = function () {
              console.error("Rybbit Analytics: failed to load");
            };
            document.head.appendChild(r);
          }
        } catch (e) {
          /* noop */
        }
      }

      if (accepted === "true") {
        loadAnalytics();
        hide();
      } else if (accepted === "false") {
        hide();
      } else if (dismissed === "true") {
        showTrigger();
        hidePanels();
      } else {
        show();
      }

      document.addEventListener("click", function (e: Event) {
        const t = e.target;
        if (!(t instanceof Element)) return;
        const actionEl = t.closest("[data-consent-action]");
        const toggleEl = t.closest("[data-consent-toggle='panel']");
        const closeEl = t.closest("[data-consent-close='panel']");

        if (toggleEl) {
          togglePanel();
          return;
        }
        if (closeEl) {
          localStorage.setItem(dismissedKey, "true");
          hidePanels();
          showTrigger();
          return;
        }

        if (actionEl && actionEl.getAttribute("data-consent-action") === "accept") {
          localStorage.setItem(storageKey, "true");
          localStorage.removeItem(dismissedKey);
          console.log(
            "User accepted analytics — attempting to load analytics providers",
          );
          loadAnalytics();
          hide();
          return;
        }

        if (actionEl && actionEl.getAttribute("data-consent-action") === "reject") {
          localStorage.setItem(storageKey, "false");
          localStorage.removeItem(dismissedKey);
          hide();
        }
      });

      window.addEventListener("resize", function () {
        const current = localStorage.getItem(storageKey);
        if (current === "true" || current === "false") {
          hide();
          return;
        }
        if (localStorage.getItem(dismissedKey) === "true") {
          showTrigger();
          hidePanels();
          return;
        }
        show();
      });
    } catch (err) {
      /* fail silently */
    }
  })();
</script>
