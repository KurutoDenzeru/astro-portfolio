---
import { getCollection, render } from "astro:content";
import type { ProjectEntryWithPreview } from "@lib/projectPreviews";

import { ChevronRight, ChevronLeft } from "lucide-react";

type Props = {
  entry: ProjectEntryWithPreview;
};

// Get the requested entry
const { entry } = Astro.props;
const { collection } = entry;
const { Content } = await render(entry);
const articlePreviewImage =
  entry.data.previewImage ?? entry.data.coverImage?.src;
const shouldHideMarkdownCoverImage = Boolean(articlePreviewImage);

// Get the next and prev entries (modulo to wrap index)
const items = (await getCollection(collection))
  .filter((post) => !post.data.draft)
  .sort(
    (
      a: { data: { date: { getTime: () => number } } },
      b: { data: { date: { getTime: () => number } } },
    ) => b.data.date.getTime() - a.data.date.getTime(),
  );
const index = items.findIndex((x: { id: string }) => x.id === entry.id);
const prev = items[(index - 1 + items.length) % items.length];
const next = items[(index + 1) % items.length];
---

<div>
  <article
    class="article-content"
    data-enhance-codeblocks
    data-has-resolved-preview={shouldHideMarkdownCoverImage ? "true" : "false"}
  >
    {
      articlePreviewImage && (
        <img
          src={articlePreviewImage}
          alt={entry.data.coverAlt}
          class="mb-6 w-full rounded-xl border border-border object-cover"
          loading="eager"
        />
      )
    }
    <Content />
  </article>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <a
      href={`/${prev.collection}/${prev.id}`}
      class="group flex items-center gap-3 rounded-lg border border-border px-4 py-3 hover:bg-muted blend"
    >
      <div
        class="order-2 w-full h-full group-hover:text-foreground group-hover:dark:text-foreground blend"
      >
        <div class="flex flex-wrap gap-2">
          <div class="text-sm uppercase">Prev</div>
        </div>
        <div class="font-semibold mt-3 text-foreground">
          {prev.data.title}
        </div>
      </div>

      <ChevronLeft
        size={16}
        strokeWidth={2}
        className="order-1 size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
        aria-hidden="true"
      />
    </a>

    <a
      href={`/${next.collection}/${next.id}`}
      class="group flex items-center gap-3 rounded-lg border border-border px-4 py-3 hover:bg-muted blend"
    >
      <div
        class="w-full h-full text-right group-hover:text-foreground group-hover:dark:text-foreground blend"
      >
        <div class="text-sm uppercase">Next</div>
        <div class="font-semibold mt-3 text-foreground">
          {next.data.title}
        </div>
      </div>

      <ChevronRight
        size={16}
        strokeWidth={2}
        className="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
        aria-hidden="true"
      />
    </a>
  </div>
</div>
