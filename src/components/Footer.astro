---
import Container from "@components/Container.astro";
import { SITE, SOCIALS } from "@consts";
import {
  Instagram,
  Youtube,
  Linkedin,
  Github,
  Twitter,
  ArrowUp,
  type LucideIcon,
} from "lucide-react";
import { Button } from "@/components/ui/button";

const IconMap: Record<string, LucideIcon> = {
  github: Github,
  twitter: Twitter,
  linkedin: Linkedin,
  youtube: Youtube,
  instagram: Instagram,
};

function getSocialIcon(name: string | undefined) {
  const key = name?.toLowerCase();
  return key ? IconMap[key] : undefined;
}

const currentYear: number = new Date().getFullYear();
---

<footer class="relative bg-background">
  <div class="animate">
    <section class="py-5">
      <Container size="lg">
        <div class="flex items-center justify-center sm:justify-end">
          <Button
            id="back-to-top"
            variant="outline"
            aria-label="Back to top of page"
            className="group flex w-fit items-center gap-2 rounded-lg border border-foreground/20 px-3 py-1.5 text-sm hover:bg-foreground/5 blend"
          >
            <ArrowUp
              className="size-4 stroke-current group-hover:stroke-black group-hover:dark:stroke-white"
            />
            <div class="text-current group-hover:text-foreground group-hover:dark:text-foreground blend">
              Back to top
            </div>
          </Button>
        </div>
      </Container>
    </section>

    <section
      class="py-5 overflow-hidden whitespace-nowrap border-t border-border"
    >
      <Container size="lg">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="flex flex-col items-center sm:items-start">
            <a
              href="/"
              class="flex gap-1 text-current hover:text-foreground dark:hover:text-foreground transition-colors duration-300 ease-in-out"
            >
              <picture class="size-10">
                <!-- Show black favicon in light mode, white favicon in dark mode -->
                <img
                  src="/icons/brand_black.svg"
                  alt={`${SITE.TITLE} logo`}
                  class="w-auto h-auto p-1 block dark:hidden"
                  loading="lazy"
                />
                <img
                  src="/icons/brand_white.svg"
                  alt={`${SITE.TITLE} logo`}
                  class="w-auto h-auto p-1 hidden dark:block"
                  loading="lazy"
                />
              </picture>
              <div class="my-auto">{SITE.TITLE}</div>
            </a>
          </div>

          <div class="flex gap-2 justify-center sm:justify-end items-center">
            <span class="relative flex h-3 w-3">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-md bg-green-300"
              ></span>
              <span
                class="relative inline-flex rounded-md h-3 w-3 bg-green-500"
              ></span>
            </span>
            All systems normal
          </div>
        </div>
      </Container>
    </section>

    <section
      class="py-5 overflow-hidden whitespace-nowrap border-t border-border"
    >
      <Container size="lg">
        <div class="h-full grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div
            class="order-2 sm:order-1 flex flex-col items-center justify-center sm:items-start"
          >
            <div class="legal">
              <a
                href="/legal/terms"
                class="text-current hover:text-foreground dark:hover:text-foreground transition-colors duration-300 ease-in-out"
              >
                Terms
              </a> |
              <a
                href="/legal/privacy"
                class="text-current hover:text-foreground dark:hover:text-foreground transition-colors duration-300 ease-in-out"
              >
                Privacy Policy
              </a>
            </div>
            <div class="text-sm mt-2">&copy; {currentYear} | All rights reserved</div>
          </div>

          <div class="order-1 sm:order-2 flex justify-center sm:justify-end">
            <div class="flex flex-wrap gap-1 items-center justify-center">
              {
                SOCIALS.map(
                  (SOCIAL: { HREF: string; NAME: string; ICON: string }) => {
                    const Comp = getSocialIcon(SOCIAL.ICON);
                    return (
                      <a
                        href={SOCIAL.HREF}
                        target="_blank"
                        aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                        class="group size-10 rounded-md p-2 items-center justify-center hover:bg-black/5 dark:hover:bg-white/20  blend"
                      >
                        {Comp ? (
                          <Comp
                            className="size-full stroke-current group-hover:stroke-black group-hover:dark:stroke-white blend"
                            aria-hidden="true"
                          />
                        ) : (
                          <svg class="size-full fill-current group-hover:fill-black group-hover:dark:fill-white blend">
                            <use href={`/social.svg#${SOCIAL.ICON}`} />
                          </svg>
                        )}
                      </a>
                    );
                  },
                )
              }
            </div>
          </div>
        </div>
      </Container>
    </section>
  </div>
</footer>

<script type="module">
  import "/js/backToTop.js";
  document.addEventListener("astro:after-swap", inintializeBackToTop);
  inintializeBackToTop();
</script>
