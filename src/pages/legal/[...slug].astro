---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { SITE } from "@consts";
import BottomLayout from "@layouts/BottomLayout.astro";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import { formatDate } from "@lib/utils";

// Enable static prerendering
export const prerender = true;

// Create the static pages for legal docs
export async function getStaticPaths() {
  const docs = await getCollection("legal");
  return docs.map((doc: { id: string }) => ({
    params: { slug: doc.id },
    props: doc,
  }));
}

// Get the requested legal doc
type Props = CollectionEntry<"legal">;
const doc = Astro.props;
const { title, date } = doc.data;
const { Content } = await render(doc);
---

<PageLayout title={title} description={`${title} for ${SITE.TITLE}`}>
  <TopLayout>
    <div class="animate space-y-3">
      <p class="text-xs font-medium uppercase tracking-widest text-accent">
        Legal
      </p>
      <h1 class="text-2xl sm:text-3xl font-semibold leading-snug tracking-tight text-foreground">
        {title}
      </h1>
      <p class="text-sm text-muted-foreground">
        Last updated: {formatDate(date)}
      </p>
      <div class="mt-4 h-px bg-border/60"></div>
    </div>
  </TopLayout>
  <BottomLayout>
    <article class="animate article-content" data-enhance-codeblocks>
      <Content />
    </article>
  </BottomLayout>
</PageLayout>
